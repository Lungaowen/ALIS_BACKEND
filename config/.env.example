SPRING_PROFILES_ACTIVE=dev

# PostgreSQL / Supabase JDBC connection
# Example: jdbc:postgresql://aws-0-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require
DB_URL=jdbc:postgresql://localhost:5432/alis
DB_USERNAME=postgres
DB_PASSWORD=change-me

# Must be at least 32 bytes for HS256 JWT signing.
ALIS_JWT_SECRET=change-this-local-secret-at-least-32-bytes
ALIS_JWT_EXPIRATION=86400000

# Local dev defaults
ALIS_FIREBASE_ENABLED=false
DDL_MODE=none
PORT=8081

# Optional AI settings
GROQ_API_KEY=
ALIS_AI_GROQ_KEY=
ALIS_AI_GROQ_MODEL=llama-3.3-70b-versatile

# Optional bootstrap admin
ALIS_SEED_ADMIN_EMAIL=
ALIS_SEED_ADMIN_NAME=System Admin
ALIS_SEED_ADMIN_PASSWORD=
